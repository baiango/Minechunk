-fn hash2(ix: i32, iy: i32, seed: u32) -> f32 {
-    let value = sin(
-        f32(ix) * 127.1 +
-        f32(iy) * 311.7 +
-        f32(seed) * 74.7
-    ) * 43758.5453123;
-    return fract(value);
-}
-
-fn fade(t: f32) -> f32 {
-    return t * t * t * (t * (t * 6.0 - 15.0) + 10.0);
-}
-
-fn lerp(a: f32, b: f32, t: f32) -> f32 {
-    return a + (b - a) * t;
-}
-
-fn value_noise_2d(x: f32, y: f32, seed: u32, frequency: f32) -> f32 {
-    let px = x * frequency;
-    let py = y * frequency;
-    let x0 = floor(px);
-    let y0 = floor(py);
-    let xf = px - x0;
-    let yf = py - y0;
-
-    let ix0 = i32(x0);
-    let iy0 = i32(y0);
-    let ix1 = ix0 + 1;
-    let iy1 = iy0 + 1;
-
-    let v00 = hash2(ix0, iy0, seed);
-    let v10 = hash2(ix1, iy0, seed);
-    let v01 = hash2(ix0, iy1, seed);
-    let v11 = hash2(ix1, iy1, seed);
-
