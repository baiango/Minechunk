-    float u = fade(xf);
-    float v = fade(yf);
-    float nx0 = lerp_f(v00, v10, u);
-    float nx1 = lerp_f(v01, v11, u);
-    return lerp_f(nx0, nx1, v) * 2.0f - 1.0f;
